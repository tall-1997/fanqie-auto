<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="基本设置"
        app:key="basic_settings">

        <SwitchPreferenceCompat
            android:key="auto_sign_enabled"
            android:title="自动签到"
            android:summary="启用自动签到功能"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="auto_task_enabled"
            android:title="自动任务"
            android:summary="启用自动任务功能"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="logging_enabled"
            android:title="日志记录"
            android:summary="启用日志记录功能"
            android:defaultValue="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="高级设置"
        app:key="advanced_settings">

        <EditTextPreference
            android:key="target_package"
            android:title="目标包名"
            android:summary="设置目标应用包名"
            android:defaultValue="com.dragon.read" />

        <EditTextPreference
            android:key="hook_timeout"
            android:title="Hook超时时间"
            android:summary="设置Hook初始化超时时间（毫秒）"
            android:defaultValue="5000" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="数据管理"
        app:key="data_management">

        <Preference
            android:key="export_config"
            android:title="导出配置"
            android:summary="导出当前配置到文件" />

        <Preference
            android:key="import_config"
            android:title="导入配置"
            android:summary="从文件导入配置" />

        <Preference
            android:key="reset_config"
            android:title="重置配置"
            android:summary="恢复默认配置" />

    </PreferenceCategory>

</PreferenceScreen>
